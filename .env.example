# 复制本文件为 .env，填入自己的真实 key 后即可运行
# .env 已在 .gitignore，不会上传；本文件是安全的模板。

# === LLM ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# DeepSeek 走 OpenAI 兼容协议，base_url 必填
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 豆包（火山方舟 Ark）—— 报告终审 debate 辩方
DOUBAO_API_KEY=...
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=...

# === 工具 ===
TAVILY_API_KEY=tvly-...

# === 可观测性（可选）===
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=multi-agent-cca

# === 运行参数 ===
LOG_LEVEL=INFO

# === 认证 ===
# 腾讯云短信（手机号验证码登录）
# 控制台：https://console.cloud.tencent.com/smsv2
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
SMS_SDK_APP_ID=
# 短信签名（需审核通过，如：Dreamcode）
SMS_SIGN_NAME=
# 验证码模板 ID（需审核通过，模板示例：您的验证码为{1}，5分钟内有效，请勿泄漏）
SMS_TEMPLATE_ID=

# Google OAuth（Google 登录）
# 控制台：https://console.cloud.google.com/apis/credentials
# 回调 URI 填：http://你的域名/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps Platform（本地生活口碑结构化取数 scrape_local_life）
# 与上面 OAuth 的 CLIENT_ID/SECRET 是两套：这是 Maps Platform API key，需在控制台开启
# Places API 并启用计费。控制台：https://console.cloud.google.com/google/maps-apis
# demo 量级（每品牌 1 次 Text Search）落在免费额度内；缺失时工具 fail-soft 降级 web_search。
GOOGLE_MAPS_API_KEY=

# === 人在环（阶段 1 完成后暂停，等待前端用户确认/修订）===
# 设为 1 时：Collector/Insight 采集完后前端弹出审查框，用户可填意见再继续生成报告
# 留空则跳过审查，直接生成报告（脚本/CI 环境）
CCA_HUMAN_REVIEW=1

# === Dev 期模型 override ===
# 开发期豆包 API 可报销时填 'doubao'，所有 agent（PM / Collector / Insight / Report）
# 都走 Doubao，业务代码零改动。副作用：跨家族 debate 退化为同家族自审，bias 隔离失效。
# 流程稳定后留空或删行，自动切回 GPT-5 + DeepSeek + Doubao 三家族原配置。
CCA_DEV_MODEL_OVERRIDE=
