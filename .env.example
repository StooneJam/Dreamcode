# 复制本文件为 .env，填入真实 key 后即可使用
# .env 已被 .gitignore，不会上传

# === LLM ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# DeepSeek 走 OpenAI 兼容协议，base_url 必填
DEEPSEEK_API_KEY=...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === 工具 ===
TAVILY_API_KEY=tvly-...

# === 可观测性（可选，但答辩很加分） ===
LANGSMITH_API_KEY=...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=multi-agent-cca

# === 运行参数 ===
LOG_LEVEL=INFO
